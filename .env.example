# =============================================================================
# MedFlow — Healthcare SaaS Platform — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="MedFlow"
NEXT_PUBLIC_APP_DESCRIPTION="World-class healthcare and clinic management platform"
NODE_ENV="development"

# -----------------------------------------------------------------------------
# Database (PostgreSQL via Prisma)
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:password@localhost:5432/medflow?schema=public"
DIRECT_URL="postgresql://postgres:password@localhost:5432/medflow?schema=public"

# -----------------------------------------------------------------------------
# NextAuth / Auth.js v5
# -----------------------------------------------------------------------------
AUTH_SECRET="your-super-secret-auth-key-min-32-chars-here"
AUTH_URL="http://localhost:3000"

# OAuth Providers (Optional — add as needed)
AUTH_GOOGLE_ID="your-google-oauth-client-id"
AUTH_GOOGLE_SECRET="your-google-oauth-client-secret"

# -----------------------------------------------------------------------------
# Email (Nodemailer / SMTP)
# -----------------------------------------------------------------------------
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="MedFlow <noreply@medflow.health>"

# For production, consider Resend or SendGrid:
# RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"

# -----------------------------------------------------------------------------
# File Uploads (UploadThing)
# -----------------------------------------------------------------------------
UPLOADTHING_SECRET="sk_live_xxxxxxxxxxxxxxxxxxxxx"
UPLOADTHING_APP_ID="your-uploadthing-app-id"

# -----------------------------------------------------------------------------
# SMS (Twilio — for SMS notifications, optional)
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_PHONE_NUMBER="+1234567890"

# -----------------------------------------------------------------------------
# Stripe (for SaaS subscription billing, optional)
# -----------------------------------------------------------------------------
STRIPE_PUBLIC_KEY="pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxx"
STRIPE_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxx"
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxxxxxxxx"

# -----------------------------------------------------------------------------
# Redis (for caching and sessions, optional but recommended)
# -----------------------------------------------------------------------------
REDIS_URL="redis://localhost:6379"

# -----------------------------------------------------------------------------
# Analytics (optional)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY="phc_xxxxxxxxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"
